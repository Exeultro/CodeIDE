# Build stage
FROM golang:1.25-alpine AS builder

WORKDIR /app

RUN apk --no-cache add git ca-certificates

COPY go.mod go.sum ./
RUN go mod download

COPY cmd/yjs-server/ ./cmd/yjs-server/

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o yjs-server ./cmd/yjs-server

FROM alpine:3.21

RUN apk --no-cache add ca-certificates tzdata

WORKDIR /app

COPY --from=builder /app/yjs-server .

EXPOSE 1234

CMD ["./yjs-server", "-addr=:1234"]